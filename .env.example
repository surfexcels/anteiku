NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Required by catalog import/admin jobs, never expose to the browser.
SUPABASE_SECRET_KEY=

# Used to build auth callback URLs in hosted environments.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Python OCR service for supplier invoices (pdfplumber + Tesseract).
OCR_SERVICE_URL=http://127.0.0.1:8000

# Server-only. Optional menu matching polish and smart waste insights.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional server cache for dashboard aggregates (Upstash Redis).
# Without these, an in-memory cache is used per server instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
